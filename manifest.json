            "arch": "amd64"
          },
          {
            "os": "linux",
            "arch": "arm64"
          },
          {
            "os": "darwin",
            "arch": "arm64"
          }
        ],
        "capabilities": [
          {
            "type": "request_router.v1",
            "id": "seerr",
            "display_name": "Seerr",
            "description": "Fulfill content requests through a Seerr (Overseerr/Jellyseerr) instance.",
            "config_schema": [
              {
                "key": "connection",
                "title": "Seerr",
                "json_schema": "{\"type\":\"object\",\"properties\":{\"supports_4k\":{\"type\":\"boolean\"},\"requester_mode\":{\"type\":\"string\"},\"auto_approve\":{\"type\":\"boolean\"},\"require_mapped_user\":{\"type\":\"boolean\"}}}",
                "admin_form": {
                  "fields": [
                    {
