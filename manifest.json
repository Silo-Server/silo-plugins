    {
      "manifest": {
        "plugin_id": "silo.manga-metadata",
        "version": "0.1.1",
        "silo_api_version": "v1",
        "supported_platforms": [
          {
            "os": "darwin",
            "arch": "arm64"
          },
          {
            "os": "linux",
            "arch": "amd64"
          },
          {
            "os": "linux",
            "arch": "arm64"
          }
        ],
        "capabilities": [
          {
            "type": "metadata_provider.v1",
            "id": "manga-metadata",
            "display_name": "Manga Metadata (MangaBaka)",
            "description": "Rich manga metadata from MangaBaka — covers, synopsis, authors, genres, publication status, publisher, and cross-provider IDs — aggregating AniList, MyAnimeList, MangaUpdates, Kitsu, Anime-Planet, and Shikimori, with a MangaDex deep fallback and AniList banner backdrops. Optional offline mode downloads MangaBaka's database for fast, rate-limit-free matching on large libraries.",
            "metadata": {
              "default_priority": {
                "manga": 1
              }
            }
          }
        ],
        "global_config_schema": [
          {
            "key": "enabled_sources",
            "title": "Enabled sources",
            "description": "Comma-separated source IDs to search (mangabaka, mangadex). Empty uses the default set.",
            "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
            "admin_form": {
              "fields": [
                {
                  "key": "value",
                  "label": "Source IDs",
                  "control": 1
                }
              ]
            }
          },
          {
            "key": "enable_local_dump",
            "title": "Use local MangaBaka dump",
            "description": "Download MangaBaka's database (~335MB, ~1.5GB on disk) for offline, rate-limit-free matching. Recommended for large libraries. Default off.",
            "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"boolean\"}}}",
            "admin_form": {
              "fields": [
                {
                  "key": "value",
                  "label": "Enable local dump",
                  "control": 5
                }
              ]
            }
          },
          {
            "key": "dump_path",
            "title": "Dump storage path",
            "description": "Override where the dump is stored. Default: OS cache dir. Point at a roomy volume if needed.",
            "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
            "admin_form": {
              "fields": [
                {
                  "key": "value",
                  "label": "Path",
                  "control": 1
                }
              ]
            }
          },
          {
            "key": "dump_refresh_hours",
            "title": "Dump refresh interval (hours)",
            "description": "How often to re-download the dump. Default 168 (weekly).",
            "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"integer\"}}}",
            "admin_form": {
              "fields": [
                {
                  "key": "value",
                  "label": "Hours",
                  "control": 4,
                  "default_value": 168
                }
              ]
            }
          },
          {
            "key": "enable_anilist_banners",
            "title": "AniList banner backdrops",
            "description": "MangaBaka has no banner art. When on, fetch a hero backdrop from AniList by id for matched series. Default on.",
            "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"boolean\"}}}",
            "admin_form": {
              "fields": [
                {
                  "key": "value",
                  "label": "Enable banners",
                  "control": 5,
                  "default_value": true
                }
              ]
            }
          }
        ],
        "presentation": {
          "display_name": "Manga Metadata",
          "summary": "Match manga and add rich metadata, covers, contributors, and publication details.",
          "description_markdown": "Uses MangaBaka as the primary source, with MangaDex as a deep fallback and optional AniList banner artwork. It can also keep a local MangaBaka database for fast, rate-limit-free matching on large libraries.",
          "setup_markdown": "Install the plugin and add **Manga Metadata** to a manga library's provider chain. The defaults use live sources. For large libraries, enable the local MangaBaka dump and ensure the configured storage path has about 1.5 GB available; the initial download is roughly 335 MB.",
          "homepage_url": "https://github.com/Silo-Server/silo-plugin-metadata-manga",
          "source_url": "https://github.com/Silo-Server/silo-plugin-metadata-manga",
          "support_url": "https://github.com/Silo-Server/silo-plugin-metadata-manga/issues",
          "changelog_url": "https://github.com/Silo-Server/silo-plugin-metadata-manga/releases",
          "publisher_name": "Silo",
          "publisher_url": "https://github.com/Silo-Server",
          "license_spdx": "AGPL-3.0-only"
        }
      },
      "repo_url": "https://github.com/Silo-Server/silo-plugin-metadata-manga",
      "checksums_url": "https://github.com/Silo-Server/silo-plugin-metadata-manga/releases/download/v0.1.1/checksums.txt",
      "binaries": {
        "darwin/arm64": {
          "url": "https://github.com/Silo-Server/silo-plugin-metadata-manga/releases/download/v0.1.1/plugin-darwin-arm64"
        },
        "linux/amd64": {
          "url": "https://github.com/Silo-Server/silo-plugin-metadata-manga/releases/download/v0.1.1/plugin-linux-amd64"
        },
        "linux/arm64": {
          "url": "https://github.com/Silo-Server/silo-plugin-metadata-manga/releases/download/v0.1.1/plugin-linux-arm64"
        }
      }
    },
    {
      "manifest": {
        "plugin_id": "silo.requests.arr",
        "version": "0.1.0",
        "silo_api_version": "v1",
        "supported_platforms": [
          {
            "os": "linux",
            "arch": "amd64"
          },
          {
            "os": "linux",
            "arch": "arm64"
          },
          {
            "os": "darwin",
            "arch": "arm64"
          }
        ],
        "capabilities": [
          {
            "type": "request_router.v1",
            "id": "arr",
            "display_name": "Sonarr / Radarr",
            "description": "Fulfills movie/series requests against multi-instance Sonarr/Radarr.",
            "config_schema": [
              {
                "key": "connection",
                "title": "Connection",
                "json_schema": "{\"type\":\"object\",\"properties\":{\"service_kind\":{\"type\":\"string\"},\"root_folder\":{\"type\":\"string\"},\"quality_profile_id\":{\"type\":\"integer\"},\"tags\":{\"type\":\"array\",\"items\":{\"type\":\"integer\"}},\"is_default\":{\"type\":\"boolean\"},\"is_4k\":{\"type\":\"boolean\"},\"is_default_4k\":{\"type\":\"boolean\"},\"search_on_add\":{\"type\":\"boolean\"},\"minimum_availability\":{\"type\":\"string\"},\"series_type\":{\"type\":\"string\"},\"season_folder\":{\"type\":\"boolean\"},\"anime_enabled\":{\"type\":\"boolean\"},\"anime_root_folder\":{\"type\":\"string\"},\"anime_quality_profile_id\":{\"type\":\"integer\"},\"anime_tags\":{\"type\":\"array\",\"items\":{\"type\":\"integer\"}}}}",
                "admin_form": {
                  "fields": [
                    {
                      "key": "service_kind",
                      "label": "Service",
                      "control": 6,
                      "required": true,
                      "options": [
                        {
                          "value": "radarr",
                          "label": "Radarr (movies)"
                        },
                        {
                          "value": "sonarr",
                          "label": "Sonarr (series)"
                        }
                      ]
                    },
                    {
                      "key": "root_folder",
                      "label": "Root folder",
                      "control": 6,
                      "dynamic_options": true
                    },
                    {
                      "key": "quality_profile_id",
                      "label": "Quality profile",
                      "control": 6,
                      "required": true,
                      "dynamic_options": true
                    },
                    {
                      "key": "tags",
                      "label": "Tags",
                      "control": 7,
                      "dynamic_options": true
                    },
                    {
                      "key": "is_default",
                      "label": "Default (HD/1080p)",
                      "control": 5,
                      "exclusive_group_field": "service_kind"
                    },
                    {
                      "key": "is_4k",
                      "label": "4K instance",
                      "control": 5
                    },
                    {
                      "key": "is_default_4k",
                      "label": "Default 4K (2160p)",
                      "control": 5,
                      "show_when": [
                        {
                          "field": "is_4k",
                          "equals": [
                            "true"
                          ]
                        }
                      ],
                      "exclusive_group_field": "service_kind"
                    },
                    {
                      "key": "search_on_add",
                      "label": "Search on add",
                      "control": 5,
                      "default_value": true
                    },
                    {
                      "key": "minimum_availability",
                      "label": "Minimum availability",
                      "control": 6,
                      "default_value": "released",
                      "options": [
                        {
                          "value": "announced",
                          "label": "Announced"
                        },
                        {
                          "value": "inCinemas",
                          "label": "In cinemas"
                        },
                        {
                          "value": "released",
                          "label": "Released"
                        }
                      ],
                      "show_when": [
                        {
                          "field": "service_kind",
                          "equals": [
                            "radarr"
                          ]
                        }
                      ]
                    },
                    {
                      "key": "series_type",
                      "label": "Series type",
                      "control": 6,
                      "default_value": "standard",
                      "options": [
                        {
                          "value": "standard",
                          "label": "Standard"
                        },
                        {
                          "value": "daily",
                          "label": "Daily"
                        },
                        {
                          "value": "anime",
                          "label": "Anime"
                        }
                      ],
                      "show_when": [
                        {
                          "field": "service_kind",
                          "equals": [
                            "sonarr"
                          ]
                        }
                      ]
                    },
                    {
                      "key": "season_folder",
                      "label": "Season folder",
                      "control": 5,
                      "default_value": true,
                      "show_when": [
                        {
                          "field": "service_kind",
                          "equals": [
                            "sonarr"
                          ]
                        }
                      ]
                    },
                    {
                      "key": "anime_enabled",
                      "label": "Enable anime overrides",
                      "control": 5
                    },
                    {
                      "key": "anime_root_folder",
                      "label": "Anime root folder",
                      "control": 6,
                      "dynamic_options": true,
                      "show_when": [
                        {
                          "field": "anime_enabled",
                          "equals": [
                            "true"
                          ]
                        }
                      ]
                    },
                    {
                      "key": "anime_quality_profile_id",
                      "label": "Anime quality profile",
                      "control": 6,
                      "dynamic_options": true,
                      "show_when": [
                        {
                          "field": "anime_enabled",
                          "equals": [
                            "true"
                          ]
                        }
                      ]
                    },
                    {
                      "key": "anime_tags",
                      "label": "Anime tags",
                      "control": 7,
                      "dynamic_options": true,
                      "show_when": [
                        {
                          "field": "anime_enabled",
                          "equals": [
                            "true"
                          ]
                        }
                      ]
                    }
                  ],
                  "submit_label": "Save connection",
                  "sections": [
                    {
                      "key": "library",
                      "title": "Library",
                      "collapsible": true,
                      "collapsed_default": true,
                      "field_keys": [
                        "service_kind",
                        "root_folder",
                        "quality_profile_id",
                        "tags",
                        "is_default",
                        "is_4k",
                        "is_default_4k",
                        "search_on_add",
                        "minimum_availability",
                        "series_type",
                        "season_folder"
                      ]
                    },
                    {
                      "key": "anime",
                      "title": "Anime overrides",
                      "field_keys": [
                        "anime_enabled",
                        "anime_root_folder",
                        "anime_quality_profile_id",
                        "anime_tags"
                      ]
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "repo_url": "https://github.com/Silo-Server/silo-plugins-requests-arr",
      "checksums_url": "https://github.com/Silo-Server/silo-plugins-requests-arr/releases/download/v0.1.0/checksums.txt",
      "binaries": {
        "darwin/arm64": {
          "url": "https://github.com/Silo-Server/silo-plugins-requests-arr/releases/download/v0.1.0/plugin-darwin-arm64"
        },
        "linux/amd64": {
          "url": "https://github.com/Silo-Server/silo-plugins-requests-arr/releases/download/v0.1.0/plugin-linux-amd64"
        },
        "linux/arm64": {
          "url": "https://github.com/Silo-Server/silo-plugins-requests-arr/releases/download/v0.1.0/plugin-linux-arm64"
        }
      }
    },
    {
      "manifest": {
